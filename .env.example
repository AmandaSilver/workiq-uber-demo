# ============================================================================
#  WorkIQ Trip Planner — configuration
#  Copy this file to `.env` and adjust. Everything has a safe default so the
#  demo runs out-of-the-box in CAPTURED mode with NO secrets required.
# ============================================================================

PORT=4317

# ----------------------------------------------------------------------------
#  WorkIQ "Ask" mode
#    captured = always replay the known-good captured dataset (default, safest)
#    live     = ALWAYS call the live WorkIQ MCP server (fails loudly if it can't)
#    auto     = try live first, fall back to captured (fallback is shown loudly)
# ----------------------------------------------------------------------------
WORKIQ_MODE=captured

# Live WorkIQ is reached by speaking MCP (stdio) to a WorkIQ MCP server.
# Point these at however you launch your WorkIQ MCP server locally.
# Example (illustrative):
#   WORKIQ_MCP_COMMAND=npx
#   WORKIQ_MCP_ARGS=-y @some-org/workiq-mcp
#   WORKIQ_MCP_TOOL=ask
WORKIQ_MCP_COMMAND=
WORKIQ_MCP_ARGS=
WORKIQ_MCP_TOOL=ask
WORKIQ_MCP_QUESTION_ARG=question
# How long to wait for a live WorkIQ answer before falling back to captured.
# A real mailbox scan takes ~25-40s on a cold start; 45s keeps the demo snappy
# while still tolerating a slow live answer.
WORKIQ_TIMEOUT_MS=90000

# ----------------------------------------------------------------------------
#  WebIQ (web search) mode
#    captured = replay captured 5-star hotel results
#    live     = call a live provider (errors loudly if it fails)
#    auto     = try live, fall back to captured (recommended for demos)
#  Live works with NO key out of the box: when neither key below is set it
#  queries the keyless OpenStreetMap Overpass API for real 5-star hotels near
#  the trip centroid. Set a key to use a true web-search provider instead.
# ----------------------------------------------------------------------------
WEBIQ_MODE=auto
# Optional live providers (preferred over Overpass when set):
#   BING_SEARCH_KEY=...     # Azure Bing Web Search v7 key
#   SERPAPI_KEY=...         # serpapi.com key
BING_SEARCH_KEY=
SERPAPI_KEY=
WEBIQ_TIMEOUT_MS=12000

# ----------------------------------------------------------------------------
#  WorkIQ "Tools" — send the summary report by email
#    preview = render the email to a local file + the UI, DO NOT send
#    draft   = save it to your Outlook Drafts via the interactive Graph worker
#              (npm run draft-worker) — never sends; safe under admin policy
#    smtp    = really send via the SMTP settings below
#  draft falls back to preview automatically if the worker isn't running.
# ----------------------------------------------------------------------------
MAIL_MODE=draft
MAIL_FROM="WorkIQ Trip Planner <trip-planner@example.com>"
MAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
